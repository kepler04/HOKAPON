# =============================================================
#  TIENDA YIENKID — Environment variables (template)
#  Copy this file to .env.local and fill in real values.
#  NEVER commit .env.local
# =============================================================

# --- Supabase (PUBLIC — safe in browser, protected by RLS) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# --- Supabase (PRIVATE — server only, NEVER prefix with NEXT_PUBLIC) ---
# Bypasses RLS. Only used inside Server Actions / Route Handlers.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Business config (public) ---
NEXT_PUBLIC_STORE_NAME=Tienda YienKid
# Admin WhatsApp number in international format, digits only (e.g. Peru: 51 + 9 digits)
NEXT_PUBLIC_WHATSAPP_PHONE=51999999999

# --- Manual payment data (shown on the success page) ---
NEXT_PUBLIC_YAPE_NUMBER=999999999
NEXT_PUBLIC_YAPE_NAME=Tienda YienKid
NEXT_PUBLIC_PLIN_NUMBER=999999999
NEXT_PUBLIC_PLIN_NAME=Tienda YienKid
NEXT_PUBLIC_BANK_NAME=BCP
NEXT_PUBLIC_BANK_HOLDER=Tienda YienKid SAC
NEXT_PUBLIC_BANK_ACCOUNT=191-XXXXXXX-0-XX
NEXT_PUBLIC_BANK_CCI=002-191-00XXXXXXX0XX-12

# --- Currency ---
NEXT_PUBLIC_CURRENCY=PEN
NEXT_PUBLIC_CURRENCY_SYMBOL=S/
